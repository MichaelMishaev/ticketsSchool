echo "🔒 Running security checks before push..."
echo ""

# NPM Audit (HIGH/CRITICAL only in production dependencies)
# Known unfixable: serialize-javascript chain via @ducanh2912/next-pwa (all versions affected, tracked 2026-04-06)
echo "🔍 Running npm audit for HIGH/CRITICAL vulnerabilities..."
AUDIT_OUTPUT=$(npm audit --audit-level=high --production 2>&1) || true
AUDIT_EXIT=$?

if [ $AUDIT_EXIT -ne 0 ]; then
  # Count total high/critical vulns vs known serialize-javascript vulns
  TOTAL_HIGH=$(echo "$AUDIT_OUTPUT" | grep -c "Severity: high\|Severity: critical" || true)
  KNOWN_HIGH=$(echo "$AUDIT_OUTPUT" | grep -c "Serialize JavaScript" || true)

  if [ "$TOTAL_HIGH" -gt "$KNOWN_HIGH" ]; then
    echo "$AUDIT_OUTPUT"
    echo ""
    echo "❌ npm audit found unknown HIGH or CRITICAL vulnerabilities!"
    echo "Please run 'npm audit' for details and fix vulnerabilities before pushing."
    echo "To bypass this check (emergency only): git push --no-verify"
    exit 1
  else
    echo "⚠️  Known unfixable: serialize-javascript via @ducanh2912/next-pwa (no upstream fix available)"
  fi
fi
echo "✅ No new HIGH/CRITICAL vulnerabilities found"
echo ""

# Secret scan with gitleaks (if installed)
if command -v gitleaks &> /dev/null; then
  echo "🔐 Scanning for secrets with gitleaks..."
  gitleaks protect --staged --verbose --no-banner
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Potential secrets detected in your code!"
    echo ""
    echo "Please remove secrets before pushing."
    echo "To bypass this check (emergency only): git push --no-verify"
    exit 1
  fi
  echo "✅ No secrets detected"
  echo ""
else
  echo "ℹ️  gitleaks not installed - skipping secret scan"
  echo "   Install with: brew install gitleaks"
  echo ""
fi

# Tests are handled by CI/CD pipeline
# If you want to run tests locally before push:
#   npm run test:canary (fast golden-path tests)
#   npm run test:p0 (full P0 suite - slow!)

echo "✅ Pre-push checks passed!"
echo "🚀 Proceeding with push..."
echo ""
echo "ℹ️  Tests will run in CI/CD pipeline"
echo "   To run locally: npm run test:canary"
